#include <behaviors.dtsi>

#define MATRIX_RC(row, col) ((row * 12) + col)

/ {
    kscan0: kscan0 {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;

        col-gpios
            = <&gpio0 6 GPIO_ACTIVE_HIGH>
            , <&gpio0 8 GPIO_ACTIVE_HIGH>
            , <&gpio0 17 GPIO_ACTIVE_HIGH>
            , <&gpio0 20 GPIO_ACTIVE_HIGH>
            , <&gpio0 22 GPIO_ACTIVE_HIGH>
            , <&gpio0 24 GPIO_ACTIVE_HIGH>
            ;

        row-gpios
            = <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio1 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&gpio0 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };

    default_transform: keymap_transform0 {
        compatible = "zmk,matrix-transform";

        columns = <12>;
        rows = <4>;

        map = <
            MATRIX_RC(0,0)  MATRIX_RC(0,1)  MATRIX_RC(0,2)  MATRIX_RC(0,3)  MATRIX_RC(0,4)  MATRIX_RC(0,5)
            MATRIX_RC(0,6)  MATRIX_RC(0,7)  MATRIX_RC(0,8)  MATRIX_RC(0,9)  MATRIX_RC(0,10) MATRIX_RC(0,11)

            MATRIX_RC(1,0)  MATRIX_RC(1,1)  MATRIX_RC(1,2)  MATRIX_RC(1,3)  MATRIX_RC(1,4)  MATRIX_RC(1,5)
            MATRIX_RC(1,6)  MATRIX_RC(1,7)  MATRIX_RC(1,8)  MATRIX_RC(1,9)  MATRIX_RC(1,10) MATRIX_RC(1,11)

            MATRIX_RC(2,0)  MATRIX_RC(2,1)  MATRIX_RC(2,2)  MATRIX_RC(2,3)  MATRIX_RC(2,4)  MATRIX_RC(2,5)
            MATRIX_RC(2,6)  MATRIX_RC(2,7)  MATRIX_RC(2,8)  MATRIX_RC(2,9)  MATRIX_RC(2,10) MATRIX_RC(2,11)

            MATRIX_RC(3,0)  MATRIX_RC(3,3)  MATRIX_RC(3,4)  MATRIX_RC(3,5)
            MATRIX_RC(3,6)  MATRIX_RC(3,7)  MATRIX_RC(3,8)  MATRIX_RC(3,11)
        >;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        kscan = <&kscan0>;
        transform = <&default_transform>;

        keys = <
            &key_physical 0 0 0 0
            &key_physical 1 0 0 0
            &key_physical 2 0 0 0
            &key_physical 3 0 0 0
            &key_physical 4 0 0 0
            &key_physical 5 0 0 0
            &key_physical 6 0 0 0
            &key_physical 7 0 0 0
            &key_physical 8 0 0 0
            &key_physical 9 0 0 0
            &key_physical 10 0 0 0
            &key_physical 11 0 0 0

            &key_physical 12 0 1 0
            &key_physical 13 0 1 0
            &key_physical 14 0 1 0
            &key_physical 15 0 1 0
            &key_physical 16 0 1 0
            &key_physical 17 0 1 0
            &key_physical 18 0 1 0
            &key_physical 19 0 1 0
            &key_physical 20 0 1 0
            &key_physical 21 0 1 0
            &key_physical 22 0 1 0
            &key_physical 23 0 1 0

            &key_physical 24 0 2 0
            &key_physical 25 0 2 0
            &key_physical 26 0 2 0
            &key_physical 27 0 2 0
            &key_physical 28 0 2 0
            &key_physical 29 0 2 0
            &key_physical 30 0 2 0
            &key_physical 31 0 2 0
            &key_physical 32 0 2 0
            &key_physical 33 0 2 0
            &key_physical 34 0 2 0
            &key_physical 35 0 2 0

            &key_physical 36 0 3 0
            &key_physical 39 0 3 0
            &key_physical 40 0 3 0
            &key_physical 41 0 3 0
            &key_physical 42 0 3 0
            &key_physical 43 0 3 0
            &key_physical 44 0 3 0
            &key_physical 47 0 3 0
        >;
    };

    split: split {
        compatible = "zmk,split";
    };
};